{
  "name": "aidom",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:client": "vite",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "db:create": "wrangler d1 create aidom-db",
    "db:init": "wrangler d1 execute aidom-db --file=server/db/schema.sql",
    "db:init:local": "wrangler d1 execute aidom-db --local --file=server/db/schema.sql",
    "db:seed:local": "wrangler d1 execute aidom-db --local --file=server/db/seed.sql"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "date-fns": "^3.6.0",
    "hono": "^4.4.0",
    "jose": "^5.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240614.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "wrangler": "^3.60.0"
  }
}
